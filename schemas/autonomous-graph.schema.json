{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-finops.local/schemas/autonomous-graph.schema.json",
  "title": "Autonomous Engineering Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "goal", "originalPromptHash", "autonomy", "createdAt", "budgets", "nodes", "metadata"],
  "properties": {
    "version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "originalPromptHash": { "type": "string", "minLength": 1 },
    "autonomy": { "enum": ["plan_only", "read_only", "workspace", "consequential"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxNodes", "maxParallel", "maxFanout", "maxDepth", "maxRepairRounds", "timeoutMs", "maxEstimatedTokens"],
      "properties": {
        "maxNodes": { "type": "integer", "minimum": 1 },
        "maxParallel": { "type": "integer", "minimum": 1, "maximum": 100 },
        "maxFanout": { "type": "integer", "minimum": 1 },
        "maxDepth": { "type": "integer", "minimum": 1 },
        "maxRepairRounds": { "type": "integer", "minimum": 0, "maximum": 5 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "maxEstimatedTokens": { "type": "integer", "minimum": 1 },
        "maxActualTokens": { "type": "integer", "minimum": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "kind", "dependsOn", "permission"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,63}$" },
          "label": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["deterministic", "agent", "parallel_map", "reduce", "verifier", "human_gate"] },
          "dependsOn": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "permission": { "enum": ["none", "read", "write", "external", "destructive"] },
          "executor": { "enum": ["codex", "claude", "local"] },
          "prompt": { "type": "string" },
          "operation": { "enum": ["identity", "collect", "flatten", "dedupe"] },
          "inputPath": { "type": "string" },
          "maxConcurrency": { "type": "integer", "minimum": 1 },
          "outputSchema": { "type": "object" },
          "isolation": { "enum": ["shared", "worktree"] },
          "metadata": { "type": "object" }
        }
      }
    },
    "repairPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "candidateNodeId", "verifierNodeId", "acceptedField", "repairExecutor", "repairPrompt"],
      "properties": {
        "enabled": { "type": "boolean" },
        "candidateNodeId": { "type": "string" },
        "verifierNodeId": { "type": "string" },
        "acceptedField": { "type": "string" },
        "repairExecutor": { "enum": ["codex", "claude", "local"] },
        "repairPrompt": { "type": "string" }
      }
    },
    "metadata": { "type": "object" }
  }
}
