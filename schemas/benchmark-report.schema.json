{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/orperelman123/autonomous-graph-engineering/main/schemas/benchmark-report.schema.json",
  "title": "Deterministic Control-Plane Benchmark Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "benchmark", "fixture", "behavior", "scope", "passed", "scenarios"],
  "properties": {
    "version": { "const": "1.0" },
    "benchmark": { "const": "deterministic-control-plane" },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "seed", "sha256", "task"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "task": { "type": "string", "minLength": 1 }
      }
    },
    "behavior": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "passed": { "type": "boolean" },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "nodeCount",
          "executorCalls",
          "verifierCalls",
          "repairRounds",
          "budgets",
          "parallelMapNodes",
          "humanGates",
          "checkpointed",
          "audited",
          "verifier",
          "usage",
          "passed"
        ],
        "properties": {
          "name": {
            "enum": ["direct-no-repair", "bounded-loop", "validated-graph"]
          },
          "status": { "enum": ["completed", "failed"] },
          "nodeCount": { "type": "integer", "minimum": 1 },
          "executorCalls": { "type": "integer", "minimum": 1 },
          "verifierCalls": { "type": "integer", "minimum": 1 },
          "repairRounds": { "type": "integer", "minimum": 0 },
          "budgets": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "maxNodes",
              "maxParallel",
              "maxFanout",
              "maxDepth",
              "maxRepairRounds",
              "timeoutMs",
              "maxEstimatedTokens",
              "maxActualTokens"
            ],
            "properties": {
              "maxNodes": { "type": "integer", "minimum": 1 },
              "maxParallel": { "type": "integer", "minimum": 1 },
              "maxFanout": { "type": "integer", "minimum": 1 },
              "maxDepth": { "type": "integer", "minimum": 1 },
              "maxRepairRounds": { "type": "integer", "minimum": 0 },
              "timeoutMs": { "type": "integer", "minimum": 1 },
              "maxEstimatedTokens": { "type": "integer", "minimum": 1 },
              "maxActualTokens": { "type": "integer", "minimum": 1 }
            }
          },
          "parallelMapNodes": { "type": "integer", "minimum": 0 },
          "humanGates": { "type": "integer", "minimum": 0 },
          "checkpointed": { "type": "boolean" },
          "audited": { "type": "boolean" },
          "verifier": {
            "type": "object",
            "additionalProperties": false,
            "required": ["accepted", "reasons"],
            "properties": {
              "accepted": { "type": "boolean" },
              "reasons": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "usage": {
            "type": "object",
            "additionalProperties": {
              "type": "number",
              "minimum": 0
            }
          },
          "passed": { "type": "boolean" }
        }
      }
    }
  }
}
