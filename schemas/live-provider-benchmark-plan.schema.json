{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/orperelman123/autonomous-graph-engineering/main/schemas/live-provider-benchmark-plan.schema.json",
  "title": "Live Provider Benchmark Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "budgetUsd", "repetitions", "timeoutMs", "maxInputTokensPerRequest", "maxOutputTokensPerRequest", "providers", "tasks"],
  "properties": {
    "version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "budgetUsd": { "type": "number", "exclusiveMinimum": 0 },
    "repetitions": { "type": "integer", "minimum": 1, "maximum": 10 },
    "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 120000 },
    "maxInputTokensPerRequest": { "type": "integer", "minimum": 256, "maximum": 1000000 },
    "maxOutputTokensPerRequest": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "providers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "model", "apiKeyEnv", "pricingUsdPerMillionTokens"],
        "properties": {
          "provider": { "enum": ["openai", "anthropic"] },
          "model": { "type": "string", "minLength": 1 },
          "apiKeyEnv": { "enum": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY"] },
          "pricingUsdPerMillionTokens": {
            "type": "object",
            "additionalProperties": false,
            "required": ["input", "cachedInput", "cacheCreationInput", "output"],
            "properties": {
              "input": { "type": "number", "exclusiveMinimum": 0 },
              "cachedInput": { "type": "number", "minimum": 0 },
              "cacheCreationInput": { "type": "number", "minimum": 0 },
              "output": { "type": "number", "exclusiveMinimum": 0 }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "provider": { "const": "openai" } }, "required": ["provider"] },
            "then": { "properties": { "apiKeyEnv": { "const": "OPENAI_API_KEY" } } },
            "else": { "properties": { "apiKeyEnv": { "const": "ANTHROPIC_API_KEY" } } }
          }
        ]
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "prompt", "requiredPhrases"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "prompt": { "type": "string", "minLength": 1 },
          "requiredPhrases": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
