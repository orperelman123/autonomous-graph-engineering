{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/orperelman123/autonomous-graph-engineering/main/schemas/portable-run-report.schema.json",
  "title": "Graph Engineer Portable Run Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "runId", "status", "graph", "execution", "verifier", "evidence", "redaction"],
  "properties": {
    "version": { "const": "1.0" },
    "runId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["running", "completed", "failed", "needs_confirmation"] },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fingerprint", "integrityVerified", "autonomy", "createdAt", "budgets", "nodes"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "fingerprint": { "type": "string", "minLength": 1 },
        "integrityVerified": { "type": "boolean" },
        "autonomy": { "enum": ["plan_only", "read_only", "workspace", "consequential"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "budgets": { "$ref": "#/$defs/budgets" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "kind", "dependsOn", "permission"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "kind": { "enum": ["deterministic", "agent", "parallel_map", "reduce", "verifier", "human_gate"] },
              "dependsOn": { "type": "array", "items": { "type": "string" } },
              "permission": { "enum": ["none", "read", "write", "external", "destructive"] },
              "executor": { "enum": ["codex", "claude", "local"] }
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedAt", "updatedAt", "repairRounds", "usage", "nodes"],
      "properties": {
        "startedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "repairRounds": { "type": "integer", "minimum": 0 },
        "usage": { "$ref": "#/$defs/usage" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "state"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "state": { "enum": ["pending", "running", "completed", "failed", "blocked", "skipped"] },
              "failureKind": { "enum": ["timeout", "budget", "executor"] },
              "startedAt": { "type": "string", "format": "date-time" },
              "completedAt": { "type": "string", "format": "date-time" },
              "usage": { "$ref": "#/$defs/usage" }
            }
          }
        }
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reasonCount"],
      "properties": {
        "nodeId": { "type": "string", "minLength": 1 },
        "accepted": { "type": "boolean" },
        "reasonCount": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkpointSha256", "auditSha256", "auditSequenceVerified", "events"],
      "properties": {
        "checkpointSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "auditSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "auditSequenceVerified": { "type": "boolean" },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sequence", "timestamp", "type"],
            "properties": {
              "sequence": { "type": "integer", "minimum": 1 },
              "timestamp": { "type": "string", "format": "date-time" },
              "type": {
                "enum": [
                  "run_started", "run_resumed", "run_completed", "run_failed", "run_blocked",
                  "node_started", "node_completed", "node_failed", "node_blocked", "node_reconciled",
                  "repair_started", "repair_completed"
                ]
              },
              "nodeId": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "omitted"],
      "properties": {
        "policy": { "const": "structural-only" },
        "omitted": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxNodes", "maxParallel", "maxFanout", "maxDepth", "maxRepairRounds", "timeoutMs", "maxEstimatedTokens"],
      "properties": {
        "maxNodes": { "type": "integer", "minimum": 1 },
        "maxParallel": { "type": "integer", "minimum": 1 },
        "maxFanout": { "type": "integer", "minimum": 1 },
        "maxDepth": { "type": "integer", "minimum": 1 },
        "maxRepairRounds": { "type": "integer", "minimum": 0 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "maxEstimatedTokens": { "type": "integer", "minimum": 1 },
        "maxActualTokens": { "type": "integer", "minimum": 1 }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "cachedInputTokens": { "type": "integer", "minimum": 0 },
        "cacheCreationInputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "reasoningOutputTokens": { "type": "integer", "minimum": 0 },
        "costUsd": { "type": "number", "minimum": 0 }
      }
    }
  }
}
