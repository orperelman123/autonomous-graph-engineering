# Deterministic local refinement is the safe default.
PROMPT_REFINER_PROVIDER=none
PROMPT_REFINER_SEMANTIC=false
PROMPT_REFINER_TIMEOUT_MS=8000
PROMPT_REFINER_HOST=127.0.0.1
PROMPT_REFINER_PORT=4317

# Optional semantic refinement. Set one provider, its API key, and an explicit
# model approved for your account. Never commit real keys.
# PROMPT_REFINER_PROVIDER=openai
# OPENAI_API_KEY=
# PROMPT_REFINER_MODEL=
#
# PROMPT_REFINER_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# PROMPT_REFINER_MODEL=
